# Redis — Standard (preferred via URL)
REDIS_URL=redis://localhost:6379

# Redis — Standard (host/port alternative)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis — Sentinel (optional; takes priority over REDIS_HOST if set)
REDIS_SENTINEL_HOSTS=sentinel1:26379,sentinel2:26379
REDIS_SENTINEL_NAME=mymaster

# Redis — Cluster (optional; takes priority over Sentinel if set)
REDIS_CLUSTER_NODES=node1:7001,node2:7002,node3:7003

# Resilience
REDIS_MAX_RETRIES=10
REDIS_CIRCUIT_BREAKER_THRESHOLD=5
REDIS_CIRCUIT_BREAKER_RESET_MS=30000
REDIS_CONNECT_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Massive (Polygon.io)
# -----------------------------------------------------------------------------
# Set to false when the WS endpoint uses a self-signed or proxy cert (dev only)
MASSIVE_WS_REJECT_UNAUTHORIZED=false
# REST polling interval (ms) used as fallback when WS plan access is unavailable (default 5000; min 2000)
MASSIVE_POLL_INTERVAL_MS=5000

# -----------------------------------------------------------------------------
# Binance (binance.com global Spot — public market data, no API key)
# -----------------------------------------------------------------------------
# Daily catalog sync cron — pulls /api/v3/exchangeInfo into binance_instruments + UIR
BINANCE_INSTRUMENT_SYNC_ENABLED=true
BINANCE_INSTRUMENTS_CRON=30 0 * * *
BINANCE_INSTRUMENTS_CRON_TZ=UTC

# Comma-separated quote-asset whitelist for sync (default: USDT,USDC,BUSD,BTC,ETH).
# Empty/unset = use defaults. Filters Binance's ~2000 spot pairs down to ~800 liquid ones.
BINANCE_QUOTES=USDT,USDC,BUSD,BTC,ETH

# Cap on exponential-backoff WS reconnect attempts before giving up (default 10)
BINANCE_WS_RECONNECT_MAX_ATTEMPTS=10
