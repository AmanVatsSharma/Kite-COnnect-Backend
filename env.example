# Database Configuration (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=trading_user
DB_PASSWORD=trading_password
DB_DATABASE=trading_app

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kite Connect Configuration (Service account)
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=your_kite_access_token
KITE_REDIRECT_URI=http://localhost:3000/api/auth/falcon/callback

# Data Provider Selection
DATA_PROVIDER=kite

# Vortex Provider Configuration
VORTEX_APP_ID=
VORTEX_API_KEY=
VORTEX_CREATE_SESSION_URL=https://vortex-api.rupeezy.in/v2/user/session
VORTEX_BASE_URL=https://vortex-api.rupeezy.in/v2
VORTEX_WS_URL=wss://wire.rupeezy.in/ws
# Max concurrent Vortex WebSockets per access token (Rupeezy cap: 3; each socket max 1000 instruments)
VORTEX_WS_MAX_SHARDS=3
VORTEX_REDIRECT_URI=http://localhost:3000/api/auth/vortex/callback
VORTEX_INSTRUMENTS_CSV_URL=https://static.rupeezy.in/master.csv

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# Admin
ADMIN_TOKEN=change_me_admin_token

# Application Configuration
PORT=3000
NODE_ENV=development

# WebSocket Configuration
WS_PORT=3001

# MeiliSearch (Search Engine)
# Primary server — always required
MEILI_HOST_PRIMARY=http://meilisearch:7700
# Secondary server — optional HA failover; leave blank for single-node
MEILI_HOST_SECONDARY=
MEILI_MASTER_KEY=change_me_dev_only
# Index name used by both search-api and search-indexer
MEILI_INDEX=instruments_v1

# search-indexer tuning
INDEXER_MODE=backfill-and-watch   # backfill | incremental | backfill-and-watch | synonyms-apply
INDEXER_BATCH_SIZE=2000
INDEXER_POLL_SEC=300              # incremental poll interval in seconds
SYN_MIN_COUNT=3                   # minimum selections before a dynamic synonym is applied
SYN_MAX_PER_SYMBOL=10

# Hydration (backend auth for LTP/quotes)
HYDRATION_API_KEY=milli-key-1

# LTP-only probe tuning (bigger candidate set improves coverage)
LTP_ONLY_PROBE_MULTIPLIER=5
SEARCH_LTP_ONLY_HYDRATE_CAP=200
SUGGEST_LTP_ONLY_HYDRATE_CAP=100
